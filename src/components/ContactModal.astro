---
// Contact modal triggered by any element with id="contact-open".
// POSTs to /api/contact (Pages Function).
---
<dialog
  id="contact-modal"
  class="w-full max-w-md border-2 border-[var(--fg)] bg-[var(--bg)] p-0 text-[var(--fg)] backdrop:bg-[color-mix(in_oklab,var(--color-ink)_60%,transparent)]"
>
  <form id="contact-form" method="dialog" class="flex flex-col gap-4 p-6">
    <div class="flex items-baseline justify-between">
      <h2 class="font-display text-2xl italic">Say hi.</h2>
      <button type="button" id="contact-close" aria-label="Close" class="font-mono text-xs uppercase tracking-widest hover:text-[var(--accent)]">close</button>
    </div>

    <p class="font-sans text-sm text-[var(--fg-soft)]">
      Lands in my inbox. I read everything; I reply when I can.
    </p>

    <label class="flex flex-col gap-1">
      <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--fg-soft)]">Name</span>
      <input
        type="text"
        name="name"
        required
        autocomplete="name"
        class="border border-[var(--fg)] bg-transparent px-3 py-2 font-sans text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)]"
      />
    </label>

    <label class="flex flex-col gap-1">
      <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--fg-soft)]">Email</span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        class="border border-[var(--fg)] bg-transparent px-3 py-2 font-sans text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)]"
      />
    </label>

    <label class="flex flex-col gap-1">
      <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--fg-soft)]">Message</span>
      <textarea
        name="message"
        required
        rows="5"
        class="border border-[var(--fg)] bg-transparent px-3 py-2 font-sans text-sm focus:outline-none focus:ring-2 focus:ring-[var(--accent)]"
      ></textarea>
    </label>

    {/* Honeypot — bots fill it in; humans don't see it. */}
    <label class="hidden" aria-hidden="true">
      Don't fill this out: <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>

    <button
      type="submit"
      id="contact-submit"
      class="border-2 border-[var(--fg)] bg-[var(--accent)] px-5 py-2 font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-ink)] shadow-[4px_4px_0_0_var(--fg)] transition-transform hover:-translate-y-0.5 hover:shadow-[6px_6px_0_0_var(--fg)] disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:translate-y-0 disabled:hover:shadow-[4px_4px_0_0_var(--fg)]"
    >
      <span data-submit-label>Send</span>
    </button>

    <p data-feedback class="hidden font-sans text-sm" role="status"></p>
  </form>
</dialog>

<script is:inline>
  (function () {
    const dialog = document.getElementById("contact-modal");
    const form = document.getElementById("contact-form");
    if (!dialog || !form) return;

    function openModal() { dialog.showModal && dialog.showModal(); }
    function closeModal() { dialog.close && dialog.close(); }

    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!target) return;
      if (target.closest && target.closest("#contact-open")) {
        e.preventDefault();
        openModal();
      } else if (target.closest && target.closest("#contact-close")) {
        e.preventDefault();
        closeModal();
      } else if (target === dialog) {
        // Click on backdrop closes modal.
        closeModal();
      }
    });

    const submitBtn = document.getElementById("contact-submit");
    const submitLabel = submitBtn?.querySelector("[data-submit-label]");
    const feedback = form.querySelector("[data-feedback]");

    function setFeedback(text, kind) {
      if (!feedback) return;
      feedback.textContent = text;
      feedback.classList.remove("hidden", "text-[var(--accent)]", "text-[var(--color-terracotta)]");
      feedback.classList.add(kind === "error" ? "text-[var(--color-terracotta)]" : "text-[var(--accent)]");
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      // Honeypot: if the bot field is filled, silently no-op.
      if (data.website) { closeModal(); return; }

      submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = "Sending...";

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name: data.name,
            email: data.email,
            message: data.message,
          }),
        });
        if (!res.ok) throw new Error(await res.text());
        setFeedback("Sent. I'll get back to you.", "ok");
        form.reset();
        if (submitLabel) submitLabel.textContent = "Send";
        submitBtn.disabled = false;
        setTimeout(closeModal, 1800);
      } catch (err) {
        console.error(err);
        setFeedback("Couldn't send. Try again, or email hello@shariq.dev directly.", "error");
        if (submitLabel) submitLabel.textContent = "Send";
        submitBtn.disabled = false;
      }
    });
  })();
</script>
