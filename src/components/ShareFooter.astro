---
interface Props {
  url: string;
  title: string;
  xHandle: string;
  feedUrl: string;
}
const { url, title, xHandle, feedUrl } = Astro.props;
const xShareUrl = `https://x.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const liShareUrl = `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`;
const xFollowUrl = `https://x.com/${xHandle}`;
---
<!-- Sticky icon rail in the left gutter on wide screens; collapses to a slim
     inline row (no gutter dependency) below 1100px. Single markup set so the
     copy/share JS binds once (no duplicate IDs). -->
<aside class="share-rail" aria-label="Share and follow">
  <div class="rail-inner">
    <button type="button" class="rail-btn" id="share-native" title="Share" aria-label="Share via system share sheet">
      <svg class="rail-main" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
    </button>
    <button type="button" class="rail-btn" id="share-copy" title="Copy link" aria-label="Copy link to clipboard">
      <svg class="rail-main" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <svg class="rail-check" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
    </button>
    <a href={xShareUrl} target="_blank" rel="noopener noreferrer" class="rail-btn" title="Post on X" aria-label="Share on X (Twitter)">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.26 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a href={liShareUrl} target="_blank" rel="noopener noreferrer" class="rail-btn" title="Share on LinkedIn" aria-label="Share on LinkedIn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
    </a>

    <span class="rail-sep" aria-hidden="true"></span>

    <a href={feedUrl} class="rail-btn" title="RSS feed" aria-label="Subscribe via RSS">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
    </a>
    <a href={xFollowUrl} target="_blank" rel="noopener noreferrer" class="rail-btn" title={`Follow @${xHandle}`} aria-label={`Follow @${xHandle} on X`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
    </a>
  </div>
</aside>

<script>
  function initShare() {
    const canonical =
      document.querySelector<HTMLLinkElement>('link[rel="canonical"]')?.href ?? window.location.href;

    const nativeBtn = document.getElementById("share-native") as HTMLButtonElement | null;
    const copyBtn = document.getElementById("share-copy") as HTMLButtonElement | null;

    if (nativeBtn) {
      if (typeof navigator.share === "function") {
        nativeBtn.addEventListener("click", () => {
          navigator.share({ url: canonical, title: document.title }).catch(() => {
            /* user dismissed — not an error */
          });
        });
      } else {
        nativeBtn.style.display = "none";
      }
    }

    if (copyBtn && typeof navigator.clipboard?.writeText === "function") {
      copyBtn.addEventListener("click", () => {
        navigator.clipboard
          .writeText(canonical)
          .then(() => {
            copyBtn.classList.add("copied");
            copyBtn.title = "Copied!";
            setTimeout(() => {
              copyBtn.classList.remove("copied");
              copyBtn.title = "Copy link";
            }, 1600);
          })
          .catch(() => {/* clipboard unavailable */});
      });
    } else if (copyBtn) {
      copyBtn.style.display = "none";
    }
  }

  // Runs once on load. (Site-wide view transitions are deferred; when they land,
  // this moves to astro:page-load — initShare() is not idempotent.)
  initShare();
</script>

<style>
  /* ── Mobile / narrow default: slim inline row at the end of the article ── */
  .share-rail {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid color-mix(in oklab, var(--fg) 12%, transparent);
  }
  .rail-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
  }
  .rail-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex: none;
    border-radius: 10px;
    border: 1px solid color-mix(in oklab, var(--fg) 14%, transparent);
    background: none;
    color: inherit;
    cursor: pointer;
    text-decoration: none;
    transition: border-color .15s, color .15s, background .15s;
  }
  .rail-btn:hover {
    border-color: var(--color-ochre);
    color: var(--color-ochre);
  }
  .rail-sep {
    flex: none;
    width: 1px;
    height: 22px;
    background: color-mix(in oklab, var(--fg) 16%, transparent);
    margin: 0 4px;
  }
  .rail-check { display: none; }
  .rail-btn.copied { border-color: var(--color-ochre); color: var(--color-ochre); }
  .rail-btn.copied .rail-main { display: none; }
  .rail-btn.copied .rail-check { display: block; }

  /* ── Desktop: sticky vertical rail in the left gutter ── */
  @media (min-width: 1100px) {
    .share-rail {
      position: absolute;
      left: -76px;
      top: 0;
      bottom: 0;
      width: 44px;
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }
    .rail-inner {
      position: sticky;
      top: 120px;
      flex-direction: column;
      gap: 8px;
    }
    .rail-sep {
      width: 22px;
      height: 1px;
      margin: 4px 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail-btn { transition: none; }
  }
</style>
