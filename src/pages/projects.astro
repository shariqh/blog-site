---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { active, built, talks, host } from "../lib/projects";
---
<BaseLayout title="Projects">
  <PageHeader
    eyebrow="Building, built, talked about"
    title="Projects"
    lead="Things I'm building, things I've built, and a few talks. Closed-source products link to their site; open-source ones link to the repo and (if there is one) the live site."
  />

  {[
    { heading: "Active", items: active },
    { heading: "Built", items: built },
    { heading: "Talks", items: talks },
  ].map((section) => (
    <section class="mb-16">
      <div class="mb-6 flex items-center gap-4">
        <h2 class="font-display text-2xl italic">{section.heading}</h2>
        <span class="h-px flex-1 bg-[color-mix(in_oklab,var(--fg)_20%,transparent)]"></span>
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--fg-soft)]">
          {String(section.items.length).padStart(2, "0")}
        </span>
      </div>

      <ul class="proj-list">
        {section.items.map((p) => (
          <li class="proj">
            <div class="proj-head">
              <a class="proj-name" href={p.site ?? p.repo} target="_blank" rel="noopener">{p.name}</a>
              {p.status && <span class="proj-status">● {p.status}</span>}
            </div>
            <p class="proj-desc" set:html={p.description} />
            <div class="proj-links">
              {p.site && <a href={p.site} target="_blank" rel="noopener">{host(p.site)} ↗</a>}
              {p.repo && <a href={p.repo} target="_blank" rel="noopener">github ↗</a>}
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--fg-soft)]">
    Want to prune this list? Edit <code>src/lib/projects.ts</code>.
  </p>
</BaseLayout>

<style>
  .proj-list { list-style: none; padding: 0; }
  .proj { padding: 22px 0; border-bottom: 1px dashed color-mix(in oklab, var(--fg) 18%, transparent); }
  .proj-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 12px; }
  .proj-name { font-family: var(--font-display); font-style: italic; font-size: 24px; color: inherit; text-decoration: none; }
  .proj-name:hover { color: var(--color-terracotta); }
  .proj-status { font-family: var(--font-mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-ochre); }
  .proj-desc { margin-top: 8px; max-width: 60ch; font-size: 15px; line-height: 1.6; color: var(--fg-soft); }
  .proj-desc :global(a) { color: var(--color-terracotta); text-decoration: underline; text-decoration-color: var(--color-ochre); text-underline-offset: 3px; }
  .proj-links { margin-top: 12px; display: flex; flex-wrap: wrap; gap: 18px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; }
  .proj-links a { text-decoration: underline; text-decoration-color: var(--color-ochre); text-underline-offset: 4px; }
  .proj-links a:hover { color: var(--color-terracotta); }
</style>
