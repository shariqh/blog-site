---
import { EYEBROW_PREFIX, type BucketKey } from "../lib/buckets";
import { formatDate } from "../lib/formatDate";

interface Props {
  href: string;
  title: string;
  date: Date;
  bucket: BucketKey;
  bucketLabel: string;
  /** Slot number "01" / "02" / etc. — visual position indicator. */
  index?: string;
  /** Bigger, more dominant card (used for the lead post on the homepage grid). */
  featured?: boolean;
}

const {
  href,
  title,
  date,
  bucket,
  bucketLabel,
  index,
  featured = false,
} = Astro.props;

// Each bucket gets a specific Tailwind class set. Leadership/Process/Notes use mode-aware
// CSS vars (defined in global.css) so they NEVER match page bg in either mode.
// Engineering (ochre) + AI (terracotta) are vibrant in both modes — left as-is.
const cellClasses: Record<BucketKey, string> = {
  leadership: "bg-[var(--bucket-leadership-bg)] text-[var(--bucket-leadership-fg)]",
  engineering: "bg-[var(--color-ochre)] text-[var(--color-ink)]",
  ai: "bg-[var(--color-terracotta)] text-[var(--color-paper)]",
  process: "bg-[var(--bucket-process-bg)] text-[var(--bucket-process-fg)]",
  notes: "bg-[var(--bucket-notes-bg)] text-[var(--bucket-notes-fg)] italic font-display",
};
---
<a
  href={href}
  class:list={[
    "group relative flex flex-col justify-between overflow-hidden border-2 border-[var(--fg)] p-5 transition-all duration-200",
    "hover:-translate-y-1 hover:shadow-[6px_6px_0_0_var(--fg)]",
    featured ? "min-h-[280px] sm:min-h-[320px] sm:p-8" : "min-h-[180px]",
    cellClasses[bucket],
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <p class="font-mono text-[10px] uppercase tracking-[0.18em] opacity-80">
      {EYEBROW_PREFIX[bucket]}{bucketLabel.toUpperCase()}
    </p>
    {index && (
      <p class="font-mono text-[10px] uppercase tracking-[0.18em] opacity-50">
        No. {index}
      </p>
    )}
  </div>

  <div>
    <h2
      class:list={[
        "leading-tight tracking-tight",
        featured ? "font-display text-3xl italic sm:text-4xl" : "text-xl font-semibold",
        bucket === "notes" && !featured && "italic",
      ]}
    >
      {title}
    </h2>
    <p class="mt-3 flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest opacity-60">
      {formatDate(date)}
      <span class="opacity-50">↗</span>
    </p>
  </div>
</a>
