---
interface Props {
  eyebrow?: string;
  /** Marked as italic-serif. Use a string with explicit line break HTML if you need control. */
  title: string;
  subtitle?: string;
  /** Path to a portrait image in /public (e.g. "/static/images/avatar.jpg"). */
  portrait?: string;
  portraitAlt?: string;
  /** Optional "currently" / status line that sits under subtitle. */
  currently?: string;
}

const { eyebrow, title, subtitle, portrait, portraitAlt, currently } = Astro.props;
---
<section class="py-12 sm:py-16">
  {portrait ? (
    <div class="grid items-start gap-8 sm:grid-cols-[auto_1fr] sm:items-center sm:gap-10">
      <img
        src={portrait}
        alt={portraitAlt ?? ""}
        width="320"
        height="320"
        class="aspect-square h-32 w-32 flex-shrink-0 border-2 border-[var(--fg)] object-cover shadow-[6px_6px_0_0_var(--accent)] sm:h-48 sm:w-48 sm:shadow-[8px_8px_0_0_var(--accent)]"
      />
      <div>
        {eyebrow && (
          <p class="mb-3 inline-block bg-[var(--fg)] px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--bg)]">
            {eyebrow}
          </p>
        )}
        <h1 class="font-display text-3xl italic leading-[1.05] tracking-tight sm:text-4xl" set:html={title} />
        {subtitle && (
          <p class="mt-4 max-w-prose font-sans text-[15px] leading-relaxed text-[var(--fg-soft)]">{subtitle}</p>
        )}
        {currently && (
          <p class="mt-4 inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--fg-soft)]">
            <span class="relative inline-flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--accent)] opacity-60"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--accent)]"></span>
            </span>
            Currently: {currently}
          </p>
        )}
      </div>
    </div>
  ) : (
    <div>
      {eyebrow && (
        <p class="mb-3 inline-block bg-[var(--fg)] px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--bg)]">
          {eyebrow}
        </p>
      )}
      <h1 class="font-display text-3xl italic leading-[1.05] tracking-tight sm:text-4xl" set:html={title} />
      {subtitle && (
        <p class="mt-4 max-w-prose font-sans text-[15px] leading-relaxed text-[var(--fg-soft)]">{subtitle}</p>
      )}
      {currently && (
        <p class="mt-4 inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--fg-soft)]">
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--accent)] opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--accent)]"></span>
          </span>
          Currently: {currently}
        </p>
      )}
    </div>
  )}
</section>
